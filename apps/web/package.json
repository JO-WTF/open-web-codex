{
  "name": "open-web-codex",
  "private": true,
  "version": "0.8.0",
  "type": "module",
  "scripts": {
    "sync:material-icons": "node scripts/sync-material-icons.mjs",
    "postinstall": "npm run sync:material-icons",
    "predev": "npm run sync:material-icons",
    "dev": "vite",
    "prebuild": "npm run sync:material-icons",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:ds": "eslint . --ext .ts,.tsx",
    "codemod:modal-shell": "node scripts/codemods/modal-shell-codemod.mjs",
    "codemod:panel-shell": "node scripts/codemods/panel-shell-codemod.mjs",
    "codemod:toast-shell": "node scripts/codemods/toast-shell-codemod.mjs",
    "codemod:ds:dry": "npm run codemod:modal-shell -- --dry-run && npm run codemod:panel-shell -- --dry-run && npm run codemod:toast-shell -- --dry-run",
    "codemod:ds": "npm run codemod:modal-shell && npm run codemod:panel-shell && npm run codemod:toast-shell",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "check:no-desktop": "node scripts/check-no-desktop.mjs",
    "check:main-ui-parity": "node scripts/check-main-ui-parity.mjs",
    "check:codex-contracts": "node scripts/check-codex-contracts.mjs",
    "check:codex-generated": "node scripts/check-codex-generated.mjs",
    "generate:codex-contracts": "node scripts/generate-codex-contract-bundle.mjs",
    "generate:codex-consumer-types": "node scripts/generate-codex-consumer-types.mjs",
    "fetch:codex-contracts": "node scripts/fetch-codex-contracts.mjs",
    "smoke:codex-app-server": "node scripts/codex-app-server-smoke.mjs --require-manifest",
    "test:codex-capabilities": "node scripts/test-codex-capability-manifest.mjs",
    "test:feature-policy": "node scripts/test-feature-policy.mjs",
    "test:codex-fixtures": "node scripts/replay-codex-fixtures.mjs --self-test && node scripts/replay-codex-fixtures.mjs",
    "test:codex-harness": "node scripts/test-codex-app-server-harness.mjs",
    "test:e2e:real-platform": "node scripts/real-platform-e2e.mjs"
  },
  "dependencies": {
    "@pierre/diffs": "^1.0.6",
    "@sentry/react": "^10.36.0",
    "@tanstack/react-virtual": "^3.13.18",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "lucide-react": "^0.562.0",
    "prismjs": "^1.30.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "vscode-material-icons": "^0.1.1"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/prismjs": "^1.26.5",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.6.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.36.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "jsdom": "^27.0.1",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^3.2.4"
  }
}
