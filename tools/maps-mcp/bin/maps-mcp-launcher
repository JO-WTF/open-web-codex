#!/usr/bin/env bash
set -euo pipefail

root_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
venv_dir="${OPEN_WEB_CODEX_MAPS_MCP_VENV:-${MAPS_MCP_VENV:-$root_dir/.venv}}"
python_bin="$venv_dir/bin/python"
data_dir="${OPEN_WEB_CODEX_DATA_DIR:-$root_dir/.local/open-web-codex}"
log_dir="${OPEN_WEB_CODEX_LOG_DIR:-$data_dir/logs}"
log_file="${OPEN_WEB_CODEX_MAPS_MCP_LAUNCHER_LOG:-$log_dir/maps-mcp-launcher.log}"

mkdir -p "$log_dir"

log() {
  printf '[%s] %s\n' "$(date -u '+%Y-%m-%dT%H:%M:%SZ')" "$*" >>"$log_file"
}

proxy_state() {
  local names=(HTTP_PROXY HTTPS_PROXY ALL_PROXY NO_PROXY http_proxy https_proxy all_proxy no_proxy)
  local name value states=()
  for name in "${names[@]}"; do
    value="${!name:-}"
    if [[ -n "$value" ]]; then
      states+=("$name=set")
    else
      states+=("$name=unset")
    fi
  done
  (IFS=,; printf '%s' "${states[*]}")
}

log "maps-mcp launcher starting"
log "root_dir=$root_dir"
log "cwd=$(pwd)"
log "args=$*"
log "venv_dir=$venv_dir"
log "python_bin=$python_bin"
log "proxy_state=$(proxy_state)"

ensure_venv() {
  if [[ ! -x "$python_bin" ]]; then
    if [[ "${MAPS_MCP_AUTO_INSTALL:-0}" != "1" ]]; then
      cat >&2 <<EOF
maps-mcp: shared Python environment is missing: $venv_dir
maps-mcp: run scripts/setup-maps-mcp-env.sh during platform startup, or set MAPS_MCP_AUTO_INSTALL=1 for manual development.
EOF
      log "missing shared Python environment"
      exit 70
    fi
    command -v python3 >/dev/null 2>&1 || {
      printf 'maps-mcp: python3 is required to create %s\n' "$venv_dir" >&2
      exit 127
    }
    python3 -m venv "$venv_dir"
    log "created Python environment via MAPS_MCP_AUTO_INSTALL"
  fi
}

ensure_dependencies() {
  if "$python_bin" - <<'PY' >/dev/null 2>&1
import maps_mcp.server  # noqa: F401
import mcp  # noqa: F401
PY
  then
    log "dependency import check passed"
    return 0
  fi
  if [[ "${MAPS_MCP_AUTO_INSTALL:-0}" != "1" ]]; then
    cat >&2 <<EOF
maps-mcp: shared Python environment is not ready: $venv_dir
maps-mcp: run scripts/setup-maps-mcp-env.sh during platform startup, or set MAPS_MCP_AUTO_INSTALL=1 for manual development.
EOF
    log "dependency import check failed"
    exit 70
  fi
  # MCP stdio uses stdout for JSON-RPC frames. Keep first-start dependency
  # installation logs off stdout; otherwise the MCP client can wait for a
  # handshake until timeout after seeing non-protocol output.
  "$python_bin" -m pip install --disable-pip-version-check -e "$root_dir" >&2
  log "installed dependencies via MAPS_MCP_AUTO_INSTALL"
}

ensure_venv
ensure_dependencies
log "python_version=$($python_bin --version 2>&1)"
log "exec maps_mcp.server"
exec "$python_bin" -m maps_mcp.server "$@" 2>>"$log_file"
