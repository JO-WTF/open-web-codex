{
  "mcpServers": {
    "workspace_maps": {
      "command": "./bin/maps-mcp-launcher",
      "args": [
        "--workspace-root",
        "."
      ],
      "cwd": ".",
      "startup_timeout_sec": 60,
      "tool_timeout_sec": 180,
      "tools": {
        "create_map_card": {
          "approval_mode": "approve"
        }
      },
      "env_vars": [
        "OPEN_WEB_CODEX_MAPS_MCP_VENV",
        "MAPS_MCP_VENV",
        "OPEN_WEB_CODEX_DATA_DIR",
        "OPEN_WEB_CODEX_LOG_DIR",
        "OPEN_WEB_CODEX_MAPS_MCP_LAUNCHER_LOG"
      ]
    }
  }
}
